# LOCAL DEVELOPMENT ONLY
# In production, the pipeline overwrites this file using GitHub Secrets.
#
# IMPORTANT - set these secrets in GitHub:
#   REACT_APP_URL_API        = https://d7hxcss83ohd2.cloudfront.net/api/v1
#   REACT_APP_WEB_SOCKET_URL = http://<EC2_PUBLIC_IP>:8080/live-match
#
# The /api/* path is proxied by CloudFront to EC2:8080 (configured in deploy.yml)
# This avoids mixed-content errors (HTTPS page -> HTTP backend)

REACT_APP_URL_API=http://localhost:8080/api/v1
REACT_APP_WEB_SOCKET_URL=http://localhost:8080/live-match
